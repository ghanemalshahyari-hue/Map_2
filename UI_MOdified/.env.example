# ───────────────────────────────────────────────────────────────────
#  RMOOZ wargame — environment configuration
#  Copy this file to .env (gitignored) or set these in your shell.
#  All variables here are OPTIONAL; the app runs without any of them
#  using the Ollama defaults from server/ai/ai-config.js.
# ───────────────────────────────────────────────────────────────────

# ── Cloud Claude (high-quality adjudication) ───────────────────────
# Get a key from https://console.anthropic.com.
# Leave blank to disable the Claude path entirely (Ollama-only).
ANTHROPIC_API_KEY=

# Which Claude model to use. Recommended for adjudication quality:
#   claude-opus-4-7              (1M context, most capable, recommended)
#   claude-sonnet-4-6            (~5x cheaper, 200k context)
#   claude-haiku-4-5-20251001    (fastest/cheapest; may lack doctrinal nuance)
RMOOZ_CLAUDE_MODEL=claude-opus-4-7

# Per-call timeout (ms) for Claude requests. With prompt caching + streaming
# Opus 4.7 typically responds in 8-15s; 90s is generous headroom.
RMOOZ_CLAUDE_TIMEOUT_MS=90000

# Upper bound on output tokens per Claude call. Adjudicator JSON is ~1500
# tokens; 4000 gives headroom for narrative variants.
RMOOZ_CLAUDE_MAX_TOKENS=4000

# ── opencode Zen (OpenAI-compatible gateway, proxies Claude + others) ──
# Use this if you can't access the Anthropic API directly but DO have a
# Zen account. Zen runs Claude under the hood via OpenAI Chat Completions
# API — works, but Anthropic prompt-caching is NOT preserved through Zen,
# so per-call cost is ~10x compared to direct Claude with caching.
OPENCODE_ZEN_API_KEY=

# Zen base URL. Default is the standard opencode.ai endpoint.
OPENCODE_ZEN_URL=https://opencode.ai/zen/v1

# Model identifier as your Zen account knows it. Confirmed against the
# live Zen catalog: plain IDs, no provider prefix. Other strong options:
#   claude-opus-4-6, claude-sonnet-4-6 (cheaper), claude-haiku-4-5 (fastest).
RMOOZ_ZEN_MODEL=claude-opus-4-7

# ── Provider selection ─────────────────────────────────────────────
#   ollama   = force local Ollama (sovereign / air-gap)
#   claude   = force direct Anthropic API (requires ANTHROPIC_API_KEY)
#   zen      = force opencode Zen gateway (requires OPENCODE_ZEN_API_KEY)
#   auto     = first configured of (claude > zen > ollama)
# Default if unset: auto
RMOOZ_AI_PROVIDER=auto

# ── Existing Ollama settings (see server/ai/ai-config.js for full list) ──
# RMOOZ_OLLAMA_URL=http://localhost:11434
# RMOOZ_OLLAMA_MODEL=llama3.2:1b
# RMOOZ_OLLAMA_API_KEY=

# ───────────────────────────────────────────────────────────────────
#  Unified Import Scenario wizard → WarGamingGEN generation
#  (UNIFIED-IMPORT-2). REQUIRED for the one-click "Start Scenario
#  Generation" button to actually run the sim. Without these, the
#  wizard fails gracefully into Advanced Tools / Continue·Restart·View Logs.
# ───────────────────────────────────────────────────────────────────

# Enable the real WarGamingGEN run trigger. "1" = the wizard's Start button
# spawns the sim; anything else = generation disabled (manual/Advanced only).
RMOOZ_ALLOW_SIM_RUN=1

# Where the WarGamingGEN / TestingAI tree lives. Default if unset:
# %USERPROFILE%\Desktop\TestingAI. Point this at your real tree.
RMOOZ_TESTINGAI_DIR=C:\Users\EngCoder\Desktop\TestingAI

# REQUIRED: the Python interpreter that has WarGamingGEN's dependencies
# installed (its virtualenv). The bridge does NOT auto-detect the venv — if
# this is unset it falls back to bare `python`, which lacks WarGamingGEN's
# deps and the run dies instantly with: ModuleNotFoundError: No module named
# 'openai'. Set this to the TestingAI venv python:
RMOOZ_PYTHON=C:\Users\EngCoder\Desktop\TestingAI\.venv\Scripts\python.exe

# Local model WarGamingGEN uses per phase (must be served, e.g. via Ollama:
# `ollama serve` + `ollama pull qwen2.5:3b`). The bridge forces
# LLM_LOCAL_FORCE_FALLBACK=0 so it actually generates.
RMOOZ_SIM_MODEL=qwen2.5:3b

# Optional: override the WarGamingGEN dir directly (defaults to
# <RMOOZ_TESTINGAI_DIR>\WarGamingGEN).
# RMOOZ_WARGAMEGEN_DIR=

# TROUBLESHOOTING
#   Symptom: "Start Scenario Generation" fails within seconds; View Logs shows
#            ModuleNotFoundError: No module named 'openai'.
#   Cause:   the RMOOZ server is invoking bare `python` instead of the
#            WarGamingGEN venv python (RMOOZ_PYTHON unset/wrong).
#   Fix:     set RMOOZ_PYTHON to the TestingAI venv python (above) and
#            RESTART the RMOOZ server, then retry Start.

# ───────────────────────────────────────────────────────────────────
#  Two ways to set ANTHROPIC_API_KEY without committing it to git:
#
#  Option A — shell env var (per-session):
#    PowerShell:  $env:ANTHROPIC_API_KEY = "sk-ant-..."
#    bash:        export ANTHROPIC_API_KEY=sk-ant-...
#
#  Option B — gitignored overlay file (persistent across restarts):
#    Create server/ai/ai-secrets.local.js with:
#      module.exports = { claude: { apiKey: 'sk-ant-...' } };
#    This file is already gitignored.
# ───────────────────────────────────────────────────────────────────
