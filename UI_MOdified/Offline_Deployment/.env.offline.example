# ─────────────────────────────────────────────────────────────────────────────
#  RMOOZ — Offline Deployment Environment Template
#  Copy this file to .env.offline and fill in the values for your site.
#  .env.offline is gitignored and must NEVER be committed to version control.
#
#  ┌─ IMPORTANT — PASSWORD POLICY ───────────────────────────────────────────┐
#  │  No password belongs in this file.                                       │
#  │  • User passwords are entered at login time through the browser form.    │
#  │  • They flow only through POST /api/auth/login and the LDAP bind.        │
#  │  • They are never stored in .env, Docker images, logs, or the database.  │
#  │  • Do not add LDAP_BIND_PASS, LDAP_PASSWORD, or any similar variable.   │
#  └──────────────────────────────────────────────────────────────────────────┘
# ─────────────────────────────────────────────────────────────────────────────

# ── Server port ───────────────────────────────────────────────────────────────
# PORT: what the container web server listens on internally. Always 5006.
PORT=5006
APP_PORT=5006

# ── Public-facing URLs (IMPORTANT for remote browser access) ──────────────────
#
# If users open the app from ANOTHER machine (not the Docker host), set these
# to the server's network-reachable IP and ports.
#
# Example: Docker runs on 155.140.70.51, users open from other machines:
#   WEB_PUBLIC_PORT=8640         ← host port mapped to container 5006
#   WEB_PUBLIC_BASE_URL=http://155.140.70.51:8640
#   TILE_PUBLIC_BASE_URL=http://155.140.70.51:8080   ← tile server public URL
#
# Without these, /api/offline/map-config returns localhost URLs which only
# work when the browser is on the same machine as Docker.

WEB_PUBLIC_PORT=8640
WEB_PUBLIC_BASE_URL=http://155.140.70.51:8640

# Tile server public URL — returned to the browser for satellite map tiles.
# If not set, falls back to LOCAL_TILE_URL which may use localhost.
TILE_PUBLIC_BASE_URL=http://155.140.70.51:8080

# MBTiles tileset name (filename without .mbtiles in map_data/base/)
RMOOZ_TILE_DATASET_NAME=satellite-2017-11-02_asia_gcc-states

# ── Authentication backend ────────────────────────────────────────────────────
# "ldap"  — authenticate users against the LDAP/Active Directory server below.
# "local" — use the built-in SQLite username/password store (development only).
RMOOZ_AUTH_BACKEND=ldap

# ── LDAP / Active Directory ───────────────────────────────────────────────────
#
# These values are site-specific. Every offline deployment must set them to
# match the LDAP server at that site. The same Docker image works at any site
# by changing these env vars only — no code rebuild is needed.
#
# ► HOW LOGIN WORKS:
#   1. User types their employee number in the browser (e.g. s1234567).
#      They do NOT type the @domain — the app adds it automatically.
#   2. User types their Windows/domain password in the browser.
#      This password is sent over HTTPS to the RMOOZ server only.
#   3. RMOOZ server forms the UPN:  s1234567@LDAP_DOMAIN
#   4. RMOOZ server attempts an LDAP simple bind with the UPN and password.
#   5. On success, RMOOZ creates a session. The password is immediately discarded.
#
# ► PASSWORD GUARANTEE:
#   - The password is NEVER stored in any database table.
#   - The password is NEVER written to any log file.
#   - The password is NEVER baked into the Docker image or this env file.
#   - The password is NEVER returned in any API response.

# IP address or hostname of the LDAP/AD server at this site.
# Must be reachable from the Docker container over TCP port LDAP_PORT.
# Replace with the actual offline LDAP server for this deployment.
# Example (development): LDAP_SERVER=155.140.4.130
# Example (site A):      LDAP_SERVER=10.10.10.5
# Example (site B):      LDAP_SERVER=ldap.internal.corp
LDAP_SERVER=<offline-ldap-ip-or-hostname>

# LDAP port.
# 389 = plain LDAP (no TLS) — sufficient on an isolated intranet.
# 636 = LDAPS (TLS) — recommended if the AD server supports it (set LDAP_USE_SSL=1 too).
LDAP_PORT=389

# Active Directory domain suffix appended to the employee number.
# The user types "s1234567"; the backend binds as "s1234567@LDAP_DOMAIN".
# Set this to the UPN suffix of the offline site's Active Directory domain.
# Example: LDAP_DOMAIN=sss.dir
# Example: LDAP_DOMAIN=corp.example.mil
# To find the correct value: ask the AD team for the userPrincipalName suffix.
LDAP_DOMAIN=<offline-domain>

# Timeout in seconds for LDAP TCP connect and bind operations.
# Increase if the LDAP server is slow to respond; decrease for faster failure detection.
LDAP_TIMEOUT=5

# TLS mode.
# 0 = plain LDAP on port 389 (default for isolated intranet deployments).
# 1 = LDAPS on port 636 (requires AD server certificate support — set LDAP_PORT=636 too).
LDAP_USE_SSL=0

# ── Offline tile server (legacy — used by the main tile-server.js on port 8080) ──
# Set to 1 to enable offline tile serving from local .mbtiles files.
# .mbtiles files must be placed in the maps/ volume directory.
OFFLINE_TILES=1

# Optional: URL of an external tile server. Leave blank when using offline tiles.
TILE_URL=

# ── Map source configuration (offline_app resolver) ───────────────────────────
#
# MAP_SOURCE_MODE controls which tile source is preferred:
#   auto     — try local tiles first; fall through to FALLBACK_TILE_URL if local is missing
#   local    — use local tiles only (fail clearly if absent, never use fallback)
#   fallback — use FALLBACK_TILE_URL only (skips local health check)
#
# For this server deployment (local MBTiles present), use "local".
MAP_SOURCE_MODE=local

# Browser-facing tile URL. MUST use the server IP (155.140.70.51), NOT localhost,
# because users open the app from other machines.
# NOTE: If TILE_PUBLIC_BASE_URL (above) is set, /api/offline/map-config derives
#       localTileUrl from it automatically and this value is a documented backup.
LOCAL_TILE_URL=http://155.140.70.51:8080/services/satellite-2017-11-02_asia_gcc-states/{z}/{x}/{y}.png

# Fallback tile URL — used only when MAP_SOURCE_MODE=auto/fallback AND local fails.
# Disabled here (MAP_FALLBACK_ENABLED=0) since local MBTiles are present.
# IMPORTANT: must be an INTERNAL network URL — never a public CDN.
FALLBACK_TILE_URL=

# Health-check tile URL — a known-good tile the resolver probes to confirm the
# tile server is reachable. MUST use the server IP, not localhost.
MAP_HEALTHCHECK_URL=http://155.140.70.51:8080/services/satellite-2017-11-02_asia_gcc-states/7/79/53.png

# 0 = never use fallback URL (local tiles or clear "unavailable").
# 1 = allow fallback URL when local tiles are absent.
MAP_FALLBACK_ENABLED=0

# Path inside the container where the offline map tile data is mounted.
# This directory is the read-only volume mount for local tiles.
# Corresponds to: volumes: ./map_data:/app/offline_map_data:ro in docker-compose.
OFFLINE_MAP_DATA_DIR=/app/offline_map_data

# ── Libya DEM elevation file ──────────────────────────────────────────────────
# Path inside the container to the Libya DEM GeoTIFF (used by Cesium 3D terrain
# and the /api/dem/* elevation API). Mounted via map_data/dem volume.
# Run prepare-map-bundle.ps1 to copy the file to Offline_Deployment/map_data/dem/.
# If missing: 3D terrain shows flat; 2D satellite tiles still work.
DEM_PATH=/app/dem_data/libya_demx5.tif

# ── Session security ──────────────────────────────────────────────────────────
# Random secret used to derive session identifiers.
# REQUIRED — change before first deployment. Re-use of the placeholder is a
# security risk: all sessions would share a predictable signing basis.
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-before-deployment

# ── Roadmap editors (ROADMAP-4) ───────────────────────────────────────────────
# The development-roadmap overlay (Roadmap button) is read-only for every
# logged-in user. Editing a roadmap item's status (POST /api/roadmap/status) is
# restricted to admins. A user is an admin if EITHER:
#   • their account role is "admin" (e.g. the local bootstrap admin), OR
#   • their username appears in this comma-separated list.
# For an LDAP site, put the employee number(s) of the roadmap owner(s) here.
# These are usernames, NOT passwords — safe to set in this file.
# Example: RMOOZ_ROADMAP_ADMINS=s1234567,s7654321
RMOOZ_ROADMAP_ADMINS=admin

# ── Offline AI / Ollama ───────────────────────────────────────────────────────
#
# ► IMPORTANT: These settings SELECT which model to call.
#   They do NOT include model weights. The model must already be installed in
#   Ollama on the offline machine before RMOOZ generation can work.
#
# ► No API key or password is required for local Ollama.
#
# ► To prepare the model for offline use:
#   1. On internet-connected machine: ollama pull qwen2.5:7b
#   2. Run: .\Offline_Deployment\scripts\export-ollama-model-info.ps1
#   3. Transfer ~/.ollama/models/ to the offline machine
#   4. On offline machine: ollama list   → must show qwen2.5:7b
#   5. Test: ollama run qwen2.5:7b "Reply with only OK"
#
# See: Offline_Deployment/docs/offline-ollama-model-package-guide.md

# RMOOZ Node server AI provider
RMOOZ_AI_PROVIDER=ollama

# Where Ollama is reachable FROM INSIDE the Docker container:
#   Docker Desktop (Windows/Mac): http://host.docker.internal:11434
#   Linux Docker without Desktop: http://172.17.0.1:11434  (host bridge IP)
#   Ollama on another machine:    http://<machine-ip>:11434
RMOOZ_OLLAMA_URL=http://host.docker.internal:11434

# Model name — must already exist in Ollama on the offline machine
# Options: qwen2.5:3b (faster), qwen2.5:7b (recommended), qwen2.5:14b, qwen2.5:32b
RMOOZ_OLLAMA_MODEL=qwen2.5:7b

# WarGamingGEN uses the same Ollama endpoint and model
OLLAMA_HOST=http://host.docker.internal:11434
RMOOZ_SIM_MODEL=qwen2.5:7b

# 1 = enable WarGamingGEN generation  |  0 = disable (map/LDAP still work)
RMOOZ_ALLOW_SIM_RUN=1

# ─────────────────────────────────────────────────────────────────────────────
#  LiteLLM / OpenAI-compatible AI endpoint (OFFLINE-RUNTIME-FIX-4)
#
#  Use when the offline site has a LiteLLM HTTPS proxy or any OpenAI-
#  compatible endpoint. The API key stays server-side only.
#
#  For Ollama on the same machine: keep RMOOZ_AI_PROVIDER=ollama (above).
#  For LiteLLM HTTPS: change to RMOOZ_AI_PROVIDER=litellm and fill below.
# ─────────────────────────────────────────────────────────────────────────────
# RMOOZ_AI_PROVIDER=litellm
# RMOOZ_AI_BASE_URL=https://litellm.tawasol.mil.ae/v1
# RMOOZ_AI_API_KEY is SECRET — set in .env.offline only, NEVER in this file
# RMOOZ_AI_MODEL=oss-120b-fast

# ─────────────────────────────────────────────────────────────────────────────
#  Generation timeout (OFFLINE-LITELLM-CERT-TIMEOUT-1)
#
#  oss-120b and oss-120b-fast can take several minutes per phase.
#  Default: 300 000 ms (5 minutes). Increase for slower models.
#  All three vars are passed to the Python generator; set any one.
# ─────────────────────────────────────────────────────────────────────────────
RMOOZ_AI_TIMEOUT_MS=300000
# LLM_TIMEOUT_MS=300000       # alias (same effect)
# OPENAI_TIMEOUT_MS=300000    # alias (same effect)

# ─────────────────────────────────────────────────────────────────────────────
#  Internal CA certificate for private HTTPS LiteLLM endpoint (OFFLINE-LITELLM-CA-1)
#
#  If the LiteLLM server uses a certificate issued by an internal/private CA
#  (e.g. tawasol-ca.crt), TLS verification will fail unless the container
#  trusts that CA.
#
#  ► HOW TO USE:
#  1. Obtain the internal CA certificate (public root/intermediate, PEM format).
#     It contains ONLY the public certificate — no private key, no secrets.
#  2. Copy it to:  bundle/certs/tawasol-ca.crt
#  3. The docker-compose volume mounts it at:
#       /app/certs/tawasol-ca.crt
#  4. Set the env vars below so Node.js and Python both trust it.
#
#  ► SECURITY NOTE:
#  TLS verification remains ON by default. The RMOOZ_AI_TLS_VERIFY=0 option
#  is an emergency last resort if the cert cannot be mounted — it is insecure
#  and should only be used temporarily while the cert is being provisioned.
#
#  ► To verify the setup after restarting the container:
#       curl http://<host>:8640/api/ai/generation-health
#  Response should show: caCertConfigured=true, caCertPathExists=true
#
#  ► The four vars below must all point at the SAME file — the exact name of
#    the CA cert you placed in bundle/certs/ (mounted read-only at /app/certs).
#    The current deployment uses ._mil_dir.crt; change the name here only if you
#    rename the file. All four are PATHS (no secret content): RMOOZ_AI_CA_CERT_PATH
#    is read by Node + the Python config; SSL_CERT_FILE + REQUESTS_CA_BUNDLE are
#    honoured by the Python TLS/HTTP stack; NODE_EXTRA_CA_CERTS by Node's TLS.
#    Never use curl -k / RMOOZ_AI_TLS_VERIFY=0 in production — trust the CA instead.
# ─────────────────────────────────────────────────────────────────────────────
RMOOZ_AI_CA_CERT_PATH=/app/certs/._mil_dir.crt
SSL_CERT_FILE=/app/certs/._mil_dir.crt
REQUESTS_CA_BUNDLE=/app/certs/._mil_dir.crt
NODE_EXTRA_CA_CERTS=/app/certs/._mil_dir.crt

# Emergency TLS override — set to 0 ONLY if cert mounting is impossible.
# RMOOZ_AI_TLS_VERIFY=0      # INSECURE — use only as a last resort

# ─────────────────────────────────────────────────────────────────────────────
#  Optional mutual TLS — client certificate (OFFLINE-LITELLM-MTLS-1)
#
#  ONLY enable this if the LiteLLM endpoint REQUIRES RMOOZ to present its OWN
#  client certificate (mutual TLS). For a normal HTTPS + Bearer-token endpoint,
#  leave all three UNSET — behaviour is then exactly as CA-trust-only.
#
#  ► HOW TO USE:
#    1. Put the client certificate + private key under bundle/certs/:
#         certs/rmooz-client.crt   (public client certificate)
#         certs/rmooz-client.key   (private key — NEVER commit to git)
#    2. Uncomment the two path vars below. Both must be set together.
#    3. If the private key is passphrase-protected, set the password var too.
#       The password is read server-side only — never logged, never returned.
#
#  Both cert and key are required together; setting only one is a config error
#  (generation-health reports errorCode "mtls_config_incomplete").
# ─────────────────────────────────────────────────────────────────────────────
# RMOOZ_AI_CLIENT_CERT_PATH=/app/certs/rmooz-client.crt
# RMOOZ_AI_CLIENT_KEY_PATH=/app/certs/rmooz-client.key
# RMOOZ_AI_CLIENT_CERT_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
#  WarGamingGEN
#  Enabled for offline deployment when Python dependencies and AI are available.
# ─────────────────────────────────────────────────────────────────────────────
RMOOZ_TESTINGAI_DIR=/app/TestingAI
RMOOZ_PYTHON=/opt/rmooz-venv/bin/python

# ─────────────────────────────────────────────────────────────────────────────
#  Bootstrap password — suppresses the BOOTSTRAP_PASSWORD.txt file on first run.
#  Only relevant when RMOOZ_AUTH_BACKEND=local (not used in LDAP mode).
#  Uncomment and set to any value to suppress the file.
# ─────────────────────────────────────────────────────────────────────────────
# RMOOZ_BOOTSTRAP_PASSWORD=disabled
