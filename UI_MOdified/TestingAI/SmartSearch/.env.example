# ============================================================================
# .env.example — template copy of .env for the DecisionMakingSteps pipeline.
# Copy this file to `.env` and fill in the secrets.  `.env` is gitignored
# (and excluded from the docker build context via .dockerignore);
# `.env.example` IS checked in so every new clone knows what knobs exist.
#
# The pipeline calls `python-dotenv`'s load_dotenv() in main.py BEFORE any
# graph/ import, so every key below is read lazily by graph/config.py into
# a frozen Config dataclass.  Anything you don't set falls back to the
# default shown in the comment on each line.
# ============================================================================

# ============================================================================
# 🟢 QUICKSTART — the only fields you must fill in for the offline machine
# ============================================================================
# Three external services. Each has its own (URL + API key + model id).
# Fill in the matching block below. Everything else has a sensible default.
#
#                    BASE URL                   API KEY              MODEL
# ──────────────────────────────────────────────────────────────────────────
# LLM        →  LLM_BASE_URL          LLM_API_KEY            LLM_MODEL
# Embedder   →  EMBED_BASE_URL        EMBED_API_KEY          EMBED_MODEL
# Reranker   →  RERANK_BASE_URL       RERANK_API_KEY         RERANK_MODEL
#
# Plus one universal: OPENAI_API_KEY must be non-empty (any placeholder will
# do — `graph/config.py` enforces non-empty at startup, but the actual auth
# header on the wire is LLM_API_KEY).
# ============================================================================

# ── LLM (any OpenAI-compatible endpoint — cloud OpenAI or local LM Studio) ──
# Used by every LLM-invoking stage: check_documents gate, Phase-2 HyDE
# (when enabled), Phase-3 prompt extractor, drafter, critique.
#
# OPENAI_API_KEY is still required (graph/config.py enforces it).  When the
# pipeline is pointed at LM Studio or another local OpenAI-compatible server,
# set this to any placeholder (e.g. "lm-studio") to satisfy the config gate —
# the active authentication header is LLM_API_KEY.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# ----------------------------------------------------------------------------
# Shared OpenAI-compatible LLM endpoint (LM Studio migration plan §5.1)
# ----------------------------------------------------------------------------
# LLM_BASE_URL   — OpenAI-compatible base URL.  Leave blank to use the default
#                  OpenAI endpoint.  LM Studio example:
#                      LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY    — bearer token for that endpoint.  Falls back to
#                  OPENAI_API_KEY when blank.  LM Studio example:
#                      LLM_API_KEY=lm-studio
# LLM_MODEL      — global fallback model name.  Used when a per-role model
#                  below is unset.  Code-side defaults still apply when BOTH
#                  the per-role and global vars are blank.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# LLM_USE_RESPONSES_API — LOCKED ON by user directive 2026-04-24.
# Every ChatOpenAI call routes through POST /v1/responses instead of
# POST /v1/chat/completions.  Flip to 0 ONLY if a specific local model
# genuinely cannot serve the Responses API — no cloud OpenAI, LM Studio
# server, or modern open model should need this.  Do not flip silently:
# the decision is recorded in CLAUDE.md / AGENTS.md / docs/memory.md.
LLM_USE_RESPONSES_API=1

# ----------------------------------------------------------------------------
# Per-role LLM model mapping (LM Studio migration plan §5.2)
# ----------------------------------------------------------------------------
# Each role picks its model in this precedence:
#   1. the role-specific env var below
#   2. LLM_MODEL (global fallback above)
#   3. a hardcoded code-side default
# Keep them blank to accept the fallback chain.
#
# PHASE1_GATE_MODEL        — check_documents sufficiency gate
# QUERY_EXPAND_LLM_MODEL   — Phase 2 HyDE (lower down this file, kept for
#                             backwards compatibility)
# PHASE3_EXTRACTOR_MODEL   — Phase 3 free-form prompt extractor
# PHASE3_DRAFT_MODEL       — Phase 3 per-group drafter
# PHASE3_CRITIQUE_MODEL    — Phase 3 per-group critic
PHASE1_GATE_MODEL=

# ============================================================================
# Dense embedder — local FastEmbed ONNX OR remote HTTP (Infinity/TEI/...)
# ============================================================================
# EMBED_PROVIDER           — "fastembed" (local in-process ONNX) or "http"
#                            (OpenAI-compatible POST /embeddings — Infinity,
#                            HuggingFace TEI, llama.cpp server with --embedding,
#                            etc.).  vector parity vs FastEmbed ONNX is good
#                            enough (cos > 0.9999) that Qdrant collections
#                            built under one path are queryable from the other.
# EMBED_BASE_URL           — only used when EMBED_PROVIDER=http.  The pipeline
#                            appends "/embeddings" to this URL.  Examples:
#                              http://infinity:7997
#                              https://embed.internal.example.com
# EMBED_API_KEY            — bearer token for the HTTP server.  Blank for
#                            servers without auth.
# EMBED_MODEL              — model id passed in the request payload.  Must be
#                            bge-m3 (or a 1024-dim normalised drop-in) to keep
#                            vector compatibility with the existing Qdrant
#                            collection — see EMBEDDER_TAG below.  Examples:
#                              BAAI/bge-m3
#                              bge-m3   (some servers register short aliases)
EMBED_PROVIDER=fastembed
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=

# ============================================================================
# Reranker — local FastEmbed ONNX OR remote HTTP (Infinity/TEI/Cohere/...)
# ============================================================================
# RERANK_PROVIDER          — "fastembed" or "http".  Reranker is stateless;
#                            you can swap freely without re-ingesting.
# RERANK_BASE_URL          — only used when RERANK_PROVIDER=http.  The pipeline
#                            appends "/rerank" to this URL.  Examples:
#                              http://infinity:7997
#                              https://rerank.internal.example.com
# RERANK_API_KEY           — bearer token for the HTTP server.
# RERANK_MODEL             — exact model id served by your endpoint.  Must
#                            return relevance_score per (query, candidate).
RERANK_PROVIDER=fastembed
RERANK_BASE_URL=
RERANK_API_KEY=
# (RERANK_MODEL + tuning knobs live in the Phase 2 section further below.)

# ── Qdrant (vector DB) ──────────────────────────────────────────────────────
# Local dev: colima + docker container on 6333.  On Ubuntu prod, set
# QDRANT_API_KEY to the server's auth key (leave blank locally).
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Docling parser acceleration ─────────────────────────────────────────────
# auto | cpu | mps | cuda.  Recommended: "auto" — Docling picks cuda on a
# GPU host, mps on macOS Apple Silicon, cpu otherwise.  The same value is
# correct on every machine.
DOCLING_DEVICE=auto

# ── FastEmbed ONNX execution providers (priority order, comma-separated) ──
# Listed in priority order: ORT tries CUDA first and falls back to CPU on
# any host without a CUDA-capable GPU.  Requires the GPU-capable
# `fastembed-gpu` + `onnxruntime-gpu` wheels (default in requirements.txt);
# those wheels physically contain BOTH the CUDA and CPU code paths and
# self-detect at session-create time.  The same line is correct on every
# target.  See TRANSFER_NOTES.md §0 for the slim CPU-only-build recipe.
EMBEDDER_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider

# ── Memory hardening: batch sizes (per memory.md locked row) ────────────────
# EMBED_BATCH_SIZE  → chunks per TextEmbedding.embed() / SparseTextEmbedding.embed()
# UPSERT_BATCH_SIZE → PointStructs per client.upsert()
EMBED_BATCH_SIZE=128
UPSERT_BATCH_SIZE=256

# ── Output directory (relative to repo root, or absolute path) ──────────────
# Layout is per-document: each source doc gets its own subfolder under this,
# containing every stage's artefact for that doc.
OUTPUT_DIR=output

# ── Qdrant collection naming ────────────────────────────────────────────────
# Full name = <COLLECTION_PREFIX>__<folder_slug>__<EMBEDDER_TAG>
# Folder manifest lives in the REGISTRY_COLLECTION collection.
COLLECTION_PREFIX=ingest
EMBEDDER_TAG=bgem3
REGISTRY_COLLECTION=_registry

# ── Upstream cache gate ─────────────────────────────────────────────────────
# Every per-doc artefact is stamped with the sha256 of its source file.  On
# rerun, stages with matching fingerprints skip their heavy work.
# FORCE_REPARSE=1 bypasses the gate entirely.  Default 0.
FORCE_REPARSE=0

# ── OCR retry on garbled text-layer rejects (plan B) ────────────────────────
# When the per-doc LLM gate rejects a doc with a "garbled / corrupt /
# unreadable" remark (or the preview has suspicious non-letter ratio),
# the pipeline retries the first-10-pages probe with
# force_full_page_ocr=True via Tesseract.  Covers the broken-ToUnicode-CMap
# failure class (see docs/pdf_failure_fallback_plan.md).
# Requires Tesseract binary on PATH — macOS: `brew install tesseract`;
# add `brew install tesseract-lang` for non-English language packs.
#
# OCR_RETRY_ON_GARBAGE     1/true/yes/on = enabled.  Default on.
# OCR_RETRY_MAX_PER_FOLDER upper bound on retries per ingest folder.  Stops
#                          a folder of unreadable files from burning
#                          unbounded OCR time.
# OCR_LANGS                comma- or plus-separated Tesseract languages
#                          (e.g. "eng", "eng+ara").  Default "eng".
OCR_RETRY_ON_GARBAGE=1
OCR_RETRY_MAX_PER_FOLDER=5
OCR_LANGS=eng+ara

# ── Phase 1 gate preview cap (§C27, 2026-04-24) ────────────────────────────
# Maximum preview characters sent to the per-doc LLM gate.  Guards against
# short-context local models (LM Studio default n_ctx=4096) silently
# dropping the prompt tail and flipping a verdict on a readable doc.  When
# truncation fires, check_documents logs one stderr line with the filename
# and original length so you can raise the cap (or the server's n_ctx) if
# real doctrine is being clipped.  Default 6000 fits comfortably alongside
# the ~2.5k-char gate system prompt in a 4k-ctx window.
PHASE1_PREVIEW_MAX_CHARS=6000

# ── HuggingFace Hub token (OPTIONAL) ────────────────────────────────────────
# FastEmbed downloads bge-m3 from aapot/bge-m3-onnx on first run (~2.3 GB).
# Unauthenticated downloads work but are rate-limited; a token removes that
# limit.  Leave blank if you do not have one — first run will just be slower.
HF_TOKEN=

# ============================================================================
# PHASE 2 — Retrieval stack
# ============================================================================
# Runtime toggles that graph/retrieval/* reads directly.  Defaults here match
# referencedocs/17_phase2_retrieval.md.

# ── Reranker — FastEmbed knobs (used when RERANK_PROVIDER=fastembed) ────────
# RERANK_MODEL         — shared between FastEmbed and HTTP paths.  For the
#                         FastEmbed path this is the HF slug FastEmbed pulls
#                         (matched against its registry).  For the HTTP path
#                         this is the model identifier passed in the /rerank
#                         payload — override to whatever your server lists.
# RERANK_MODEL_SOURCE  — HF source for the FastEmbed ONNX export only.
# RERANK_TOP_N_IN      — pool size fed into the reranker.
# RERANK_TOP_K_OUT     — final returned size after reranking.
# RERANK_BATCH_SIZE    — rerank.rerank() batch size (memory hardening).
# RERANKER_PROVIDERS   — ONNX execution providers for the cross-encoder.
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MODEL_SOURCE=Xenova/bge-reranker-v2-m3
RERANK_TOP_N_IN=50
RERANK_TOP_K_OUT=10
RERANK_BATCH_SIZE=16
RERANKER_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider

# ── Hybrid retrieval prefetch sizes ─────────────────────────────────────────
HYBRID_DENSE_PREFETCH=60
HYBRID_SPARSE_PREFETCH=60

# ── Query expansion toggles ─────────────────────────────────────────────────
QUERY_EXPAND_ACRONYMS=1
QUERY_EXPAND_HYDE=0
# !!! REASONING-MODEL DEPLOYMENT NOTE — bump this cap before turning HyDE on
# !!! against a reasoning model (Gemma 3/4, GPT-o1, DeepSeek-R1, etc.).
# Reasoning models consume hidden chain-of-thought tokens BEFORE producing
# visible output; on Gemma 4-e4b the reasoning step alone burned ~1018
# tokens in our smoke run.  A 256-token cap leaves zero budget for the
# visible HyDE hypothesis → silent failure (responses_client raises
# `produced no final text`, retrieval falls back to the raw query).
# Recommended values:
#   * Non-reasoning model (gpt-4o-mini, llama-3-instruct):  256  (default)
#   * Reasoning model (any Gemma 3/4, o1, R1):             2048
# Same warning applies to any other tight max_output_tokens cap added later.
# Audit with `grep -rn max_output_tokens` after swapping the LLM model.
QUERY_EXPAND_HYDE_MAX_TOKENS=256
QUERY_EXPAND_LLM_MODEL=gpt-4o-mini
HYDE_DOMAIN=us_army_doctrine

# ── Eval/feedback log (optional; Streamlit writes here) ─────────────────────
EVAL_FEEDBACK_PATH=data/eval/feedback.jsonl

# ============================================================================
# PHASE 3 — Document generation (MDMP Step 1 v1 = Time Analysis + WARNO)
# ============================================================================
# These knobs live only in Phase 3 (graph/generation/*).  Defaults here match
# referencedocs/18_phase3_generation.md §7.  Keep extractor temperature at 0.0
# — determinism is load-bearing for the prompt-sha256 cache key (§C16).

# ── Prompt extractor LLM ────────────────────────────────────────────────────
# Converts the user's free-form operation brief into a validated
# Phase3Inputs via .with_structured_output().  See §C16.
#
# Leave PHASE3_EXTRACTOR_MODEL blank to fall back to LLM_MODEL, then to the
# code-side default.  Temperature is honoured exactly (NOT run through the
# model fallback chain) so the prompt-sha256 cache key stays stable.
PHASE3_EXTRACTOR_MODEL=gpt-4o-mini
PHASE3_EXTRACTOR_TEMPERATURE=0.0

# ── Draft + critique LLM (per-group) ────────────────────────────────────────
# Drafter fills YAML-templated fields from retrieved chunks; critic passes
# each draft once to catch doctrine contradictions and citation gaps.
# Both participate in the LM Studio model fallback chain above.
PHASE3_DRAFT_MODEL=gpt-4o-mini
PHASE3_DRAFT_TEMPERATURE=0.2
PHASE3_CRITIQUE_MODEL=gpt-4o-mini
PHASE3_CRITIQUE_TEMPERATURE=0.0

# ── Per-group retrieval sizing ──────────────────────────────────────────────
# PHASE3_TOP_K_PER_QUERY — hits fetched per seed query (pre-merge).
# PHASE3_MERGE_POOL_SIZE — RRF-merged pool size fed into the single final
#                          rerank pass across all seeds (§C8).
# PHASE3_MERGED_TOP_K    — final hits handed to the drafter.
PHASE3_TOP_K_PER_QUERY=20
PHASE3_MERGE_POOL_SIZE=60
PHASE3_MERGED_TOP_K=10

# ── Per-group draft cache ───────────────────────────────────────────────────
# The generator caches the assembled `GeneratedDocument` pydantic instance
# per-group (NOT the rendered .docx — docx bytes are not deterministic).
# Set to 1 to force a full regenerate even on cache hit.
#
# Note: the cache key folds in the resolved LLM endpoint identity
# (LLM_BASE_URL or "openai-default") so switching from cloud OpenAI to LM
# Studio automatically invalidates prior entries without PHASE3_FORCE_REGENERATE.
PHASE3_FORCE_REGENERATE=0

# ── Tiered retrieval (§C31, 2026-04-27) ─────────────────────────────────────
# Phase 7 of the locked tiered-retrieval plan turns YAML-driven tier
# policies on.  Every legacy template stays at "operationalfiles_only"
# unless its YAML opts in to one of the 6 policies via `policy:`.
# Knobs below feed the cache key (so flipping any of them invalidates
# affected groups) and the coverage gate.

# Default policy applied to groups that don't declare `policy:` in YAML.
# Six valid values:
#   source_files_only        — uploaded files only; no Qdrant fan-out
#   operationalfiles_only    — legacy default; today's behaviour
#   doctrine_only            — fan out doctrine reference library only
#   operationalfiles_then_doctrine  — DEFAULT.  ops first, doctrine fallback when coverage weak
#   operationalfiles_and_doctrine   — both unconditionally
#   all_channels             — source_files + ops + doctrine
PHASE3_DEFAULT_TIER_POLICY=operationalfiles_only

# Coverage gate thresholds (used only by tier-aware groups).  Three signals;
# all three must pass for "strong", else doctrine fallback fires under the
# "operationalfiles_then_doctrine" policy.
#   tau_strong: minimum top rerank score
#   k_strong  : minimum pool size after merge+rerank
#   m_docs    : minimum distinct source_doc count
PHASE3_COVERAGE_TAU_STRONG=0.30
PHASE3_COVERAGE_K_STRONG=8
PHASE3_COVERAGE_M_DOCS=2

# Kill-switch.  Set to 0 to behave like Phase 6 (legacy operationalfiles-only)
# even for templates whose YAML declares tier-aware policies — useful for
# rolling back without re-editing YAML.  Default 1 (tiered retrieval ON).
PHASE3_TIERED_RETRIEVAL=0

# ============================================================================
# PROVIDER-BASED MODEL ROUTING (2026-04-24 override — user directive)
# ============================================================================
# The repo now supports swapping LLM, dense-embedder, and reranker between
# in-process (FastEmbed) and HTTP (any OpenAI-compatible server — LM Studio,
# Infinity, TEI, llama.cpp server, offline Linux box) by editing the vars
# below.  BM25 sparse retrieval is deliberately NOT part of this abstraction
# — it's a scoring algorithm, not a model, and stays in-process always.
#
# FASTEMBED REMAINS A FIRST-CLASS FALLBACK.  Setting EMBED_PROVIDER=fastembed
# or RERANK_PROVIDER=fastembed fully exercises the legacy ONNX path.  Neither
# setting is "deprecated" — both are the correct choice when running
# offline without an HTTP model server.

# ── Dense embedder provider ─────────────────────────────────────────────────
# EMBED_PROVIDER    fastembed | http   (alias: lm_studio = http)
# EMBED_BASE_URL    base URL up to and including /v1  (e.g. http://localhost:1234/v1)
# EMBED_API_KEY     bearer token (use "lm-studio" for LM Studio with no auth)
# EMBED_MODEL       model identifier served by the endpoint
#                   (e.g. "bge-m3" / "text-embedding-bge-m3" — match what
#                    GET /v1/models returns on your server)
#
# RE-INGEST WARNING: bge-m3 served over HTTP (llama.cpp GGUF) is NOT
# guaranteed to produce vectors bit-identical to FastEmbed's ONNX path.
# If you flip EMBED_PROVIDER=http on a corpus already ingested through
# fastembed, probe parity first (python -m graph.shared.embedders probe
# "sample text" from both configurations) and re-ingest the corpus when
# vectors drift.
EMBED_PROVIDER=fastembed
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=

# ── Reranker provider ───────────────────────────────────────────────────────
# RERANK_PROVIDER   fastembed | http   (alias: lm_studio = http)
#
# Simple rules for the HTTP path:
#   1. GET /v1/models is ONLY for discovering the model id served by the
#      rerank server.  It does not do any reranking.
#   2. Reranking itself requires a real inference endpoint, either:
#        - /v1/rerank    (most OpenAI-compatible rerank servers)
#        - /rerank       (some builds expose it at the root)
#      One of these two must actually respond to POST.
#   3. RERANK_BASE_URL is the PARENT URL.  The app appends "/rerank" to it.
#        - if the server exposes /v1/rerank →
#              RERANK_BASE_URL=http://host:port/v1
#        - if the server exposes /rerank at the root →
#              RERANK_BASE_URL=http://host:port
#   4. RERANK_MODEL must be the EXACT id returned by GET /v1/models on the
#      target rerank server.  When RERANK_PROVIDER=fastembed this value is
#      instead the HF slug matched against FastEmbed's registry (default
#      BAAI/bge-reranker-v2-m3 below).
#
# RERANK_API_KEY    bearer token for the rerank server.  Can differ from
#                   LLM_API_KEY / EMBED_API_KEY — separate servers, ports,
#                   and tokens are all independently supported.
#
# Sanity-check before going live:
#   curl -sS "$RERANK_BASE_URL/models" | jq .          # discovery
#   curl -sS -X POST "$RERANK_BASE_URL/rerank" \
#        -H "authorization: Bearer $RERANK_API_KEY" \
#        -H 'content-type: application/json' \
#        -d "{\"model\":\"$RERANK_MODEL\",\"query\":\"x\",\"documents\":[\"a\",\"b\"]}"
#   # expect: {"results":[{"index":0,"relevance_score":...}, ...]}
#   # or     : {"results":[{"index":0,"score":...}, ...]}   (also accepted)
#
# GRACEFUL DEGRADATION: if the HTTP rerank endpoint is unreachable, the
# retrieval pipeline logs a warning and returns RRF-only results rather
# than hard-failing.  See graph/retrieval/search.py.
RERANK_PROVIDER=fastembed
RERANK_BASE_URL=
RERANK_API_KEY=

# ============================================================================
# WORKED EXAMPLES — two supported deployments
# ============================================================================
# These are commented reference blocks.  Copy the block you need into `.env`
# and substitute real values; do NOT uncomment them here (this file is the
# shared template checked into git).
#
# ----------------------------------------------------------------------------
# (A) CURRENT MACHINE — LM Studio on localhost, reranker stays on FastEmbed
# ----------------------------------------------------------------------------
# Rationale: LM Studio on the dev box exposes /v1/models, /v1/responses,
# and /v1/embeddings, but /v1/rerank is build-dependent and NOT confirmed
# live on this host.  Keep the FastEmbed reranker until the HTTP endpoint
# is probed and verified with the curl sanity-check above.
#
#   OPENAI_API_KEY=lm-studio           # placeholder — graph/config.py still requires a value
#
#   LLM_BASE_URL=http://localhost:1234/v1
#   LLM_API_KEY=lm-studio
#   LLM_MODEL=google/gemma-4-e4b       # exact id from GET /v1/models on LM Studio
#   LLM_USE_RESPONSES_API=1            # LOCKED — do not flip without a user directive
#
#   EMBED_PROVIDER=http
#   EMBED_BASE_URL=http://localhost:1234/v1
#   EMBED_API_KEY=lm-studio
#   EMBED_MODEL=text-embedding-bge-m3  # exact id from GET /v1/models on LM Studio
#
#   RERANK_PROVIDER=fastembed          # in-process ONNX via BAAI/bge-reranker-v2-m3
#   # RERANK_BASE_URL / RERANK_API_KEY / RERANK_MODEL not needed in this mode
#
# ----------------------------------------------------------------------------
# (B) OFFLINE MACHINE — reranker on a separate server / IP
# ----------------------------------------------------------------------------
# On the offline box, the reranker can live at its own IP address and port,
# completely separate from the LLM and the embedder.  Each provider is
# configured independently by endpoint URL + API key + exact model id.
# No code changes are needed as long as the rerank server accepts POST at
# the expected path and returns the standard results shape.
#
# LLM, embedder, and reranker can each point at a different host — nothing
# requires them to share an IP, port, or auth token.
#
#   OPENAI_API_KEY=<placeholder or real key — must be non-empty>
#
#   LLM_BASE_URL=http://<llm-host>:<llm-port>/v1
#   LLM_API_KEY=<llm-token>
#   LLM_MODEL=<exact id from GET {LLM_BASE_URL}/models>
#   LLM_USE_RESPONSES_API=1
#
#   EMBED_PROVIDER=http
#   EMBED_BASE_URL=http://<embed-host>:<embed-port>/v1
#   EMBED_API_KEY=<embed-token>
#   EMBED_MODEL=<exact id from GET {EMBED_BASE_URL}/models>
#
#   # Offline machine example — reranker on separate server/IP
#   RERANK_PROVIDER=http
#   RERANK_BASE_URL=http://192.168.1.50:7997/v1
#   RERANK_API_KEY=<token>
#   RERANK_MODEL=<exact model id returned by GET http://192.168.1.50:7997/v1/models>
#
#   # If the server exposes /rerank at the root instead of /v1/rerank, use:
#   # RERANK_BASE_URL=http://192.168.1.50:7997

# ── i9 24-core CPU thread tuning (added for Linux/x86_64 deployment) ────────
OMP_NUM_THREADS=24
MKL_NUM_THREADS=24
