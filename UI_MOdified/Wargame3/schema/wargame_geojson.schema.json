{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wargame-generator.example/wargame_geojson.schema.json",
  "title": "Wargame GeoJSON FeatureCollection (v2)",
  "description": "Per-phase wargame snapshot. Extends standard GeoJSON FeatureCollection with domain-specific Feature subtypes discriminated by properties.kind. RFC 7946-compliant on the GeoJSON wire level; this schema describes the application semantics on top.",
  "type": "object",
  "required": ["type", "features"],
  "properties": {
    "type": { "const": "FeatureCollection" },
    "name": { "type": "string", "description": "e.g. 'step05' or 'all_phases'" },
    "properties": {
      "type": "object",
      "description": "FeatureCollection-level metadata (not part of strict RFC 7946 but tolerated; renderers should treat as opaque if unknown).",
      "properties": {
        "version":                  { "const": 2 },
        "phase":                    { "type": "integer", "minimum": 0, "maximum": 30 },
        "time_label":               { "type": "string", "description": "e.g. 'D-7', 'D+24h'" },
        "phase_name_ar":            { "type": "string", "description": "Phase name in Arabic" },
        "kind":                     { "type": "string", "description": "Phase kind, e.g. 'shaping', 'h_hour_strike'" },
        "phase_line_km":            { "type": "number", "minimum": 0 },
        "combined_effect":          { "type": "string", "description": "Adjudicator narrative for this phase" },
        "step_advantage":           { "type": "string", "enum": ["RED_ADV", "CONTESTED", "BLUE_ADV"] },
        "force_ratio_local":        { "type": "number" },
        "force_ratio_operational":  { "type": "number" },
        "n_units":                  { "type": "integer", "minimum": 0 },
        "n_actors":                 { "type": "integer", "minimum": 0 },
        "n_affected":               { "type": "integer", "minimum": 0 },
        "n_engagement_arcs":        { "type": "integer", "minimum": 0 },
        "operation_name":           { "type": "string", "description": "Only on the combined 'all_phases.geojson' file" }
      },
      "additionalProperties": true
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/Feature" }
    }
  },

  "$defs": {

    "Feature": {
      "type": "object",
      "required": ["type", "geometry", "properties"],
      "properties": {
        "type": { "const": "Feature" }
      },
      "oneOf": [
        { "$ref": "#/$defs/Feature_objective" },
        { "$ref": "#/$defs/Feature_phase_line" },
        { "$ref": "#/$defs/Feature_off_map_marker" },
        { "$ref": "#/$defs/Feature_unit" },
        { "$ref": "#/$defs/Feature_engagement_arc" }
      ]
    },

    "Position": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": { "type": "number" }
    },

    "Point": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Point" },
        "coordinates": { "$ref": "#/$defs/Position" }
      }
    },

    "LineString": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "LineString" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/Position" }
        }
      }
    },

    "_BaseProps": {
      "type": "object",
      "required": ["kind", "phase"],
      "properties": {
        "kind":  { "type": "string" },
        "phase": { "type": "integer", "minimum": 0, "maximum": 30 }
      }
    },

    "Feature_objective": {
      "type": "object",
      "properties": {
        "geometry":   { "$ref": "#/$defs/Point" },
        "properties": {
          "allOf": [
            { "$ref": "#/$defs/_BaseProps" },
            {
              "type": "object",
              "required": ["kind", "id"],
              "properties": {
                "kind":                 { "const": "objective" },
                "id":                   { "type": "string", "description": "e.g. 'OBJ-X'" },
                "name_ar":              { "type": "string" },
                "name_en":              { "type": "string" },
                "depth_km_from_coast":  { "type": ["number", "null"] }
              }
            }
          ]
        }
      }
    },

    "Feature_phase_line": {
      "type": "object",
      "properties": {
        "geometry":   { "$ref": "#/$defs/LineString" },
        "properties": {
          "allOf": [
            { "$ref": "#/$defs/_BaseProps" },
            {
              "type": "object",
              "required": ["kind", "phase_line_km", "time_label"],
              "properties": {
                "kind":            { "const": "phase_line" },
                "phase_line_km":   { "type": "number", "minimum": 0 },
                "time_label":      { "type": "string" }
              }
            }
          ]
        }
      }
    },

    "Feature_off_map_marker": {
      "type": "object",
      "properties": {
        "geometry":   { "$ref": "#/$defs/Point" },
        "properties": {
          "allOf": [
            { "$ref": "#/$defs/_BaseProps" },
            {
              "type": "object",
              "required": ["kind", "id", "side", "type"],
              "properties": {
                "kind":     { "const": "off_map_marker" },
                "id":       { "type": "string" },
                "name_ar":  { "type": "string" },
                "side":     { "type": "string", "enum": ["RED", "BLUE"] },
                "type":     { "type": "string", "description": "naval_base | air_base | ssm_brigade | logistics_node" }
              }
            }
          ]
        }
      }
    },

    "Feature_unit": {
      "type": "object",
      "properties": {
        "geometry":   { "$ref": "#/$defs/Point" },
        "properties": {
          "allOf": [
            { "$ref": "#/$defs/_BaseProps" },
            {
              "type": "object",
              "required": ["kind", "uid", "side", "domain", "type",
                           "current_strength", "initial_strength", "destroyed",
                           "suppressed_pct", "delayed_pct",
                           "prev_lon", "prev_lat", "is_actor", "is_affected"],
              "properties": {
                "kind":              { "const": "unit" },
                "uid":               { "type": "string", "description": "Stable unit ID from OOB" },
                "side":              { "type": "string", "enum": ["RED", "BLUE"] },
                "domain":            { "type": "string", "enum": ["strategic", "naval", "air", "ground", "sof"] },
                "type":              { "type": "string", "description": "Sub-type, e.g. 'destroyer', 'fighter_ad', 'mech_brigade'" },
                "name_ar":           { "type": "string" },
                "echelon":           { "type": "string", "description": "div|bde|bn|coy|sqn|flot|unit" },

                "current_strength":  { "type": "number", "minimum": 0 },
                "initial_strength":  { "type": "number", "minimum": 0 },
                "destroyed":         { "type": "boolean" },
                "suppressed_pct":    { "type": "number", "minimum": 0, "maximum": 1 },
                "delayed_pct":       { "type": "number", "minimum": 0, "maximum": 1 },

                "magazine":          { "type": ["integer", "null"] },
                "airframes":         { "type": ["integer", "null"] },
                "hulls_remaining":   { "type": ["integer", "null"] },

                "prev_lon":          { "type": "number", "description": "Position in previous phase (for animation lerp)" },
                "prev_lat":          { "type": "number" },

                "is_actor":          { "type": "boolean" },
                "is_affected":       { "type": "boolean" },

                "action_component":      { "type": "string", "enum": ["strategic","maritime","air","mines","usv_uav","sof","land","ew"] },
                "action_what":           { "type": "string" },
                "action_why":            { "type": "string" },
                "action_intended_effect":{ "type": "string" },
                "action_doctrine_cited": { "type": "array", "items": { "type": "string" } },

                "status_change":     { "type": "string", "enum": ["destroyed", "damaged_partial", "suppressed", "delayed", "expended", "unchanged"] },
                "damage_pct":        { "type": "number", "minimum": 0, "maximum": 1 },
                "cause_actor":       { "type": "string", "description": "UID of the actor that caused this outcome" },
                "cause_what":        { "type": "string" },
                "cause_doctrine":    { "type": "string" }
              },
              "if":   { "properties": { "is_actor":    { "const": true } } },
              "then": { "required":  ["action_component", "action_what"] },
              "else": { },
              "allOf": [
                {
                  "if":   { "properties": { "is_affected": { "const": true } } },
                  "then": { "required":  ["status_change", "cause_actor"] }
                }
              ]
            }
          ]
        }
      }
    },

    "Feature_engagement_arc": {
      "type": "object",
      "properties": {
        "geometry":   { "$ref": "#/$defs/LineString" },
        "properties": {
          "allOf": [
            { "$ref": "#/$defs/_BaseProps" },
            {
              "type": "object",
              "required": ["kind", "cause_actor", "target_uid", "status_change",
                           "actor_side", "target_side"],
              "properties": {
                "kind":           { "const": "engagement_arc" },
                "cause_actor":    { "type": "string", "description": "UID of attacker" },
                "target_uid":     { "type": "string", "description": "UID of target" },
                "status_change":  { "type": "string", "enum": ["destroyed", "damaged_partial", "suppressed", "delayed", "expended", "unchanged"] },
                "damage_pct":     { "type": "number", "minimum": 0, "maximum": 1 },
                "cause_what":     { "type": "string" },
                "cause_doctrine": { "type": "string" },
                "actor_side":     { "type": "string", "enum": ["RED", "BLUE"] },
                "target_side":    { "type": "string", "enum": ["RED", "BLUE"] }
              }
            }
          ]
        }
      }
    }
  }
}
