{
  "name": "rmooz",
  "version": "1.0.0",
  "description": "Offline tactical map planner",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/tile-server.js",
    "serve": "set RMOOZ_ALLOW_SIM_RUN=1&& set RMOOZ_TESTINGAI_DIR=C:\\Users\\ADMIN\\Desktop\\MAP_2\\UI_MOdified\\TestingAI&& set RMOOZ_PYTHON=C:\\Users\\ADMIN\\AppData\\Local\\Programs\\Python\\Python313\\python.exe&& set RMOOZ_SIM_MODEL=qwen2.5:7b&& node server/web-server.js",
    "seed": "node scripts/seed-units.js",
    "web": "set RMOOZ_ALLOW_SIM_RUN=1&& set RMOOZ_TESTINGAI_DIR=C:\\Users\\ADMIN\\Desktop\\MAP_2\\UI_MOdified\\TestingAI&& set RMOOZ_PYTHON=C:\\Users\\ADMIN\\AppData\\Local\\Programs\\Python\\Python313\\python.exe&& set RMOOZ_SIM_MODEL=qwen2.5:7b&& node server/web-server.js",
    "app": "concurrently \"npm run start\" \"npm run serve\"",
    "port-scenarios": "node scripts/port-wargame2.js && node scripts/port-wargame1.js",
    "test-scenarios": "node scripts/test-scenarios.js",
    "electron": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir",
    "icon": "node scripts/make-icon.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "better-sqlite3": "^12.10.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.1",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.rmooz.app",
    "productName": "rmooz",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "extraResources": [],
    "files": [
      "electron/**",
      "server/**",
      "client/**",
      "lib/**",
      "assets/**",
      "vendor/**",
      "build/icon.*",
      "package.json",
      "!*.md",
      "!*.xlsx",
      "!temp-fragments.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
