{
  "name": "rmooz",
  "version": "1.0.0",
  "description": "Offline tactical map planner",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/tile-server.js",
    "serve": "node server/web-server.js",
    "web": "node server/web-server.js",
    "app": "concurrently \"npm run start\" \"npm run serve\"",
    "electron": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir",
    "icon": "node scripts/make-icon.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "jimp": "^0.22.12",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.rmooz.app",
    "productName": "rmooz",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "extraResources": [],
    "files": [
      "electron/**",
      "server/**",
      "client/**",
      "lib/**",
      "assets/**",
      "vendor/**",
      "build/icon.*",
      "package.json",
      "!*.md",
      "!*.xlsx",
      "!temp-fragments.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
